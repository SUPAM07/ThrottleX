# ============================================================
# ThrottleX Backend — Production Environment (Render)
# ============================================================
# Copy this file to .env (or set these as environment variables
# in your Render service dashboard).
# Values marked REQUIRED must be set before deploying.
# ============================================================

# ----- Server -----------------------------------------------
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ----- Redis  -----------------------------------------------
# REQUIRED: External Redis URL (e.g. Upstash, Redis Cloud, or
#           a Render Redis instance).
#   Upstash:      rediss://:password@hostname:port
#   Redis Cloud:  redis://:password@hostname:port
#   Render Redis: redis://red-xxxxxxxx:6379
REDIS_URL=

# Set to true when using TLS (e.g. Upstash uses rediss://)
REDIS_TLS=false

# Leave blank unless your Redis instance requires a password
# separate from the URL (some providers embed it in the URL).
REDIS_PASSWORD=

REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_CONNECT_TIMEOUT=5000
REDIS_COMMAND_TIMEOUT=2000
REDIS_POOL_SIZE=5

# ----- Rate Limiting ----------------------------------------
DEFAULT_RATE_LIMIT=100
DEFAULT_WINDOW_MS=60000
DEFAULT_ALGORITHM=token_bucket

# ----- Adaptive Rate Limiting --------------------------------
ADAPTIVE_ENABLED=true
ADAPTIVE_WINDOW_MS=60000

# ----- Geo Limiting -----------------------------------------
# Disable on Render free tier (no persistent disk for GeoIP DB)
GEO_ENABLED=false

# ----- Metrics ----------------------------------------------
METRICS_ENABLED=true

# ----- Admin ------------------------------------------------
# REQUIRED: Set this to a strong random secret before deploying.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=

# ----- Circuit Breaker --------------------------------------
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_MS=30000

# ----- CORS -------------------------------------------------
# Comma-separated list of allowed origins, or leave blank for *
# CORS_ORIGINS=https://your-frontend.onrender.com
