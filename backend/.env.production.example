# ThrottleX Backend — Production Environment Variables
# Copy this file to .env and fill in the real values before running in production.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── Upstash Redis (REST credentials — recommended for Render) ─────────────────
# Create a free database at https://console.upstash.com
# These two variables are automatically converted to the correct ioredis URL.
UPSTASH_REDIS_REST_URL=https://your-db-name-12345.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>

# ── Redis (standard TCP — alternative to Upstash REST above) ──────────────────
# Use this if you have a traditional Redis instance (e.g. Render Redis add-on).
# Leave blank when UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN are set.
# REDIS_URL=rediss://default:<password>@<host>:<port>
# REDIS_PASSWORD=
# REDIS_TLS=true

# ── Redis tuning (optional) ───────────────────────────────────────────────────
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_CONNECT_TIMEOUT=5000
REDIS_COMMAND_TIMEOUT=2000
REDIS_POOL_SIZE=10

# ── Rate Limiting Defaults ────────────────────────────────────────────────────
DEFAULT_RATE_LIMIT=100
DEFAULT_WINDOW_MS=60000
DEFAULT_ALGORITHM=token_bucket

# ── Adaptive Rate Limiting ────────────────────────────────────────────────────
ADAPTIVE_ENABLED=true
ADAPTIVE_WINDOW_MS=60000

# ── Feature Flags ─────────────────────────────────────────────────────────────
GEO_ENABLED=true
METRICS_ENABLED=true

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_MS=30000

# ── Admin API ─────────────────────────────────────────────────────────────────
# CHANGE THIS — use a long, random string in production
ADMIN_API_KEY=change-me-in-production
