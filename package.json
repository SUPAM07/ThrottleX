{
  "name": "distributed-rate-limiter",
  "version": "1.0.0",
  "description": "Production-ready distributed rate limiter with Redis backing, 5 algorithms, adaptive ML rate limiting, and geo awareness",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main/server.ts",
    "build": "tsc",
    "start": "node dist/main/server.js",
    "test": "vitest run",
    "test:unit": "vitest run src/test/unit",
    "test:integration": "vitest run src/test/integration",
    "test:load": "vitest run src/test/load",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "benchmark": "ts-node src/main/benchmark/scenarioRunner.ts",
    "redis:init": "bash scripts/redis-init.sh"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cron": "^3.1.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "geoip-lite": "^1.4.10",
    "hdr-histogram-js": "^3.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "ip-range-check": "^0.2.0",
    "lru-cache": "^10.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "prom-client": "^15.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitest/coverage-v8": "^1.0.4",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "rate-limiter",
    "distributed",
    "redis",
    "token-bucket",
    "sliding-window",
    "adaptive",
    "geo-limiting",
    "microservices",
    "typescript"
  ],
  "author": "Distributed Rate Limiter Team",
  "license": "MIT"
}
